<?xml version="1.0" encoding="UTF-8"?>
<Configuration>
    <Appenders>
        <Console name="CONSOLE">
            <PatternLayout pattern="%d{HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n"/>
        </Console>
        <JTextAreaAppender name="UI">
            <PatternLayout pattern="%d{HH:mm:ss} %level{length=1} - %msg%n"/>
        </JTextAreaAppender>
    </Appenders>
    <Loggers>
        <Root level="INFO">
            <AppenderRef ref="CONSOLE"/>
        </Root>
        <Logger name="ELECT_LOG" additivity="false">
            <AppenderRef ref="UI"/>
        </Logger>
    </Loggers>
</Configuration>